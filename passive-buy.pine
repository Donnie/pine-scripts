//@version=6
indicator("Passive buy", shorttitle="Passive", overlay=true, timeframe="W")

dropPct            = input.float(5.0, "Drop % threshold", minval=0.1, maxval=50.0, step=0.5) / 100
showFiftyTwoWeekHighPlot = input.bool(true, "Show 52w High")
showLastBuyPlot    = input.bool(true, "Show Last Buy")
showBuySignals     = input.bool(true, "Show Buy Signals")

var float lastBuyPrice = na

fiftyTwoWeekHigh    = ta.highest(high, 52)
dropBelowHigh       = fiftyTwoWeekHigh * (1 - dropPct)
dropBelowLastBuy    = lastBuyPrice * (1 - dropPct)

touchedFiftyTwoWeekHigh = not na(fiftyTwoWeekHigh) and high == fiftyTwoWeekHigh
priceIsChopFromHigh     = not na(fiftyTwoWeekHigh) and close <= dropBelowHigh
priceIsChopFromLastBuy  = na(lastBuyPrice) or close <= dropBelowLastBuy

buySignal = priceIsChopFromHigh and priceIsChopFromLastBuy

if touchedFiftyTwoWeekHigh
    lastBuyPrice := na

if buySignal
    lastBuyPrice := close

plot(showFiftyTwoWeekHighPlot ? fiftyTwoWeekHigh : na, "52w High", color=color.orange, linewidth=2)
plot(showLastBuyPlot ? lastBuyPrice : na, "Last Buy", color=color.teal, linewidth=2, style=plot.style_stepline)

plotshape(
     showBuySignals ? buySignal : false,
     title="Buy",
     style=shape.arrowup,
     location=location.belowbar,
     color=color.new(color.red, 0),
     size=size.normal)
